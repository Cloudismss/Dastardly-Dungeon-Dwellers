{
  "productName": "ddd",
  "version": "0.1.0",
  "identifier": "com.ddd.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dastardly Dungeon Dwellers",
        "width": 1000,
        "height": 600,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/ddd-engine"
    ]
  }
}
